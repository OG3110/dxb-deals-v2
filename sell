<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<script>
gsap.registerPlugin(ScrollTrigger);

/* ── Burger ── */
const burger = document.getElementById('burger');
const mobileMenu = document.getElementById('mobileMenu');
burger.addEventListener('click', () => mobileMenu.classList.toggle('open'));
mobileMenu.querySelectorAll('a').forEach(a =>
  a.addEventListener('click', () => mobileMenu.classList.remove('open'))
);

/* ── Hero animations ── */
const tl = gsap.timeline({ defaults:{ ease:'power3.out' } });
tl.to('#heroKicker',  { opacity:1, duration:.55, delay:.15 })
  .to('#heroTitle',   { opacity:1, y:0, duration:.75 }, '-=.25')
  .to('#heroSub',     { opacity:1, duration:.6 }, '-=.4')
  .to('.hero-badge',  { opacity:1, y:0, duration:.5, stagger:.09 }, '-=.35')
  .to('#heroActions', { opacity:1, duration:.5 }, '-=.3');

/* ── Hero parallax ── */
gsap.to('.hero-bg', {
  yPercent: 20, ease:'none',
  scrollTrigger:{ trigger:'.hero', start:'top top', end:'bottom top', scrub:true }
});

/* ── Process section ── */
gsap.to(['#processKicker','#processTitle','#processDesc'], {
  opacity:1, y:0, duration:.7, ease:'power2.out', stagger:.1,
  scrollTrigger:{ trigger:'#process', start:'top 85%', toggleActions:'play none none none' }
});
gsap.to(['#pc1','#pc2','#pc3','#pc4'], {
  opacity:1, y:0, duration:.65, ease:'power2.out', stagger:.12,
  scrollTrigger:{ trigger:'.process-grid', start:'top 82%', toggleActions:'play none none none' }
});

/* ── Confidentiality card ── */
gsap.from('#confCard', {
  opacity:0, y:36, duration:.8, ease:'power2.out',
  scrollTrigger:{ trigger:'#confSection', start:'top 82%', toggleActions:'play none none none' }
});
gsap.to('#confList li', {
  opacity:1, x:0, duration:.55, ease:'power2.out', stagger:.12,
  scrollTrigger:{ trigger:'#confList', start:'top 85%', toggleActions:'play none none none' }
});

/* ── Final CTA ── */
gsap.to(['#ctaTitle','#ctaDesc','#ctaActions'], {
  opacity:1, y:0, duration:.7, ease:'power2.out', stagger:.12,
  scrollTrigger:{ trigger:'#finalCta', start:'top 85%', toggleActions:'play none none none' }
});

/* ── Footer year ── */
document.getElementById('yr').textContent = new Date().getFullYear();

/* ── Reduced motion ── */
if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
  gsap.globalTimeline.timeScale(0);
}
</script>
