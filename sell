<style>
/* ─── RESET ────────────────────────────────────────────────── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
body{font-family:'Outfit',sans-serif;background:#F6F2EA;color:#16302C;line-height:1.65;-webkit-font-smoothing:antialiased;overflow-x:hidden}
img{display:block;max-width:100%}
a{text-decoration:none;color:inherit}
button{font-family:inherit;cursor:pointer;border:none;background:none}

/* ─── VARIABLES ────────────────────────────────────────────── */
:root{
  --teal:#0F2C30;--teal-2:#173D42;--teal-3:#0A1E22;
  --gold:#FBD558;--gold-deep:#B5862A;--gold-soft:#FDF6DC;
  --paper:#F6F2EA;--paper-2:#EEE8D6;--card:#FFFFFF;
  --ink:#16302C;--ink-soft:#52615B;--muted:#8A938E;
  --line:#E4DDCD;--line-soft:#EDE7DA;
  --radius:18px;--radius-sm:10px;--maxw:1200px;
  --shadow-card:0 8px 32px -8px rgba(15,44,48,.14);
  --shadow-hover:0 24px 48px -18px rgba(15,44,48,.32);
}

/* ─── LAYOUT ───────────────────────────────────────────────── */
.wrap{max-width:var(--maxw);margin:0 auto;padding:0 28px}

/* ─── NAV ──────────────────────────────────────────────────── */
.nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  padding:0 28px;display:flex;align-items:center;justify-content:space-between;height:72px;
  background:rgba(246,242,234,.92);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
  border-bottom:1px solid rgba(228,221,205,.6);
}
.nav-logo{height:44px;width:auto}
.nav-links{display:flex;align-items:center;gap:36px}
.nav-links a{
  font-size:14.5px;font-weight:500;color:var(--ink-soft);
  position:relative;padding-bottom:2px;transition:color .2s;
}
.nav-links a.active{color:var(--teal);font-weight:600}
.nav-links a::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1.5px;background:var(--gold-deep);transition:width .25s}
.nav-links a:hover::after,.nav-links a.active::after{width:100%}
.nav-links a:hover{color:var(--teal)}
.nav-wa{
  display:inline-flex;align-items:center;gap:8px;background:var(--teal);color:#fff;
  font-size:14px;font-weight:600;padding:11px 20px;border-radius:999px;
  transition:background .2s,transform .2s;white-space:nowrap;
}
.nav-wa:hover{background:var(--teal-2);transform:translateY(-1px)}
.burger{display:none;width:40px;height:40px;border-radius:8px;align-items:center;justify-content:center;border:1px solid var(--line);transition:.2s}
.burger:hover{background:var(--paper-2)}
.mobile-menu{
  display:none;position:fixed;inset:0;z-index:99;background:var(--paper);
  flex-direction:column;padding:88px 28px 40px;gap:4px;
  transform:translateX(100%);transition:transform .35s cubic-bezier(.4,0,.2,1);
}
.mobile-menu.open{transform:none}
.mobile-menu a{font-size:22px;font-family:'Cormorant Garamond',serif;font-weight:600;color:var(--ink);padding:14px 0;border-bottom:1px solid var(--line);transition:color .2s}
.mobile-menu a:hover{color:var(--teal)}
.mobile-menu .mob-wa{margin-top:24px;display:flex;align-items:center;justify-content:center;gap:10px;background:var(--teal);color:#fff;padding:16px;border-radius:var(--radius-sm);font-weight:600;font-size:16px}

/* ─── HERO ─────────────────────────────────────────────────── */
.hero{
  position:relative;padding-top:72px;
  min-height:100svh;display:flex;align-items:flex-end;overflow:hidden;
}
.hero-bg{
  position:absolute;inset:0;
  background:var(--teal-3);
  background-image:url('hero.jpg');
  background-size:cover;background-position:center 30%;
}
.hero-bg::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(
    to bottom,
    rgba(10,30,34,.2) 0%,
    rgba(10,30,34,.05) 30%,
    rgba(10,30,34,.6) 65%,
    rgba(10,30,34,.92) 100%
  );
}
.hero-content{
  position:relative;z-index:2;width:100%;
  max-width:var(--maxw);margin:0 auto;padding:0 28px 80px;
}
.hero-kicker{
  display:inline-block;font-size:11px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;
  color:var(--gold);border:1px solid rgba(251,213,88,.35);
  padding:6px 14px;border-radius:999px;margin-bottom:20px;opacity:0;
}
.hero-title{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(44px,8vw,96px);font-weight:600;
  line-height:.95;letter-spacing:-.02em;color:#fff;
  max-width:800px;margin-bottom:20px;opacity:0;transform:translateY(24px);
}
.hero-title em{font-style:italic;color:var(--gold)}
.hero-sub{
  font-size:clamp(15px,1.9vw,18px);font-weight:300;
  color:rgba(246,242,234,.8);max-width:540px;
  margin-bottom:32px;opacity:0;
}
.hero-badges{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:36px}
.hero-badge{
  display:inline-flex;align-items:center;gap:8px;
  font-size:13px;font-weight:500;color:rgba(246,242,234,.9);
  background:rgba(255,255,255,.08);border:1px solid rgba(251,213,88,.25);
  padding:8px 16px;border-radius:999px;backdrop-filter:blur(6px);
  opacity:0;transform:translateY(10px);
}
.hero-badge svg{color:var(--gold)}
.hero-actions{display:flex;flex-wrap:wrap;gap:14px;opacity:0}
.btn-dark{
  display:inline-flex;align-items:center;gap:9px;
  background:var(--teal);color:#fff;
  font-size:15px;font-weight:600;
  padding:14px 26px;border-radius:999px;
  border:2px solid transparent;
  transition:background .2s,transform .2s;
}
.btn-dark:hover{background:var(--teal-2);transform:translateY(-2px)}
.btn-light{
  display:inline-flex;align-items:center;gap:9px;
  background:transparent;color:#fff;
  font-size:15px;font-weight:600;
  padding:12px 24px;border-radius:999px;
  border:2px solid rgba(255,255,255,.4);
  transition:border-color .2s,background .2s,transform .2s;
}
.btn-light:hover{border-color:#fff;background:rgba(255,255,255,.1);transform:translateY(-2px)}

/* ─── SECTION KICKER ───────────────────────────────────────── */
.sec-kicker{
  display:inline-block;
  font-size:10.5px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;
  color:var(--gold-deep);background:var(--gold-soft);
  padding:5px 14px;border-radius:999px;margin-bottom:16px;
}

/* ─── PROCESS SECTION ──────────────────────────────────────── */
.process{padding:100px 0}
.process-head{
  display:flex;justify-content:space-between;align-items:flex-end;
  flex-wrap:wrap;gap:24px;margin-bottom:60px;
}
.process-head h2{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(36px,5.5vw,62px);
  font-weight:600;line-height:1.02;letter-spacing:-.02em;max-width:500px;
}
.process-head-right{font-size:15px;color:var(--ink-soft);max-width:320px;line-height:1.6}
.process-grid{
  display:grid;grid-template-columns:repeat(2,1fr);gap:20px;
}
.process-card{
  background:var(--card);border:1px solid var(--line);
  border-radius:var(--radius);padding:36px 32px;
  box-shadow:var(--shadow-card);
  transition:transform .3s,box-shadow .3s,border-color .3s;
  opacity:0;transform:translateY(32px);
}
.process-card:hover{transform:translateY(-5px);box-shadow:var(--shadow-hover);border-color:rgba(251,213,88,.4)}
.process-num{
  font-family:'Cormorant Garamond',serif;
  font-size:52px;font-weight:700;
  color:var(--gold);line-height:1;
  margin-bottom:20px;letter-spacing:-.02em;
}
.process-card h3{
  font-family:'Cormorant Garamond',serif;
  font-size:24px;font-weight:600;line-height:1.2;
  margin-bottom:12px;
}
.process-card p{font-size:15px;color:var(--ink-soft);line-height:1.65}

/* ─── CONFIDENTIALITY SECTION ──────────────────────────────── */
.confidential{padding:0 0 100px}
.confidential-card{
  background:var(--teal);border-radius:var(--radius);
  padding:64px 72px;
  display:grid;grid-template-columns:1fr 1fr;
  gap:60px;align-items:center;
  position:relative;overflow:hidden;
}
.confidential-card::before{
  content:'';position:absolute;
  top:-100px;right:-100px;
  width:380px;height:380px;border-radius:50%;
  background:radial-gradient(circle,rgba(251,213,88,.1),transparent 70%);
  pointer-events:none;
}
.conf-kicker{
  font-size:10.5px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;
  color:rgba(251,213,88,.7);margin-bottom:16px;
}
.confidential-card h2{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(30px,4vw,48px);font-weight:600;
  color:#fff;line-height:1.05;margin-bottom:16px;
}
.confidential-card > div > p{font-size:15px;color:rgba(246,242,234,.72);line-height:1.65}
.conf-list{list-style:none;display:flex;flex-direction:column;gap:16px}
.conf-list li{
  display:flex;align-items:center;gap:14px;
  font-size:15px;font-weight:500;color:rgba(246,242,234,.88);
  opacity:0;transform:translateX(-16px);
}
.conf-list li svg{
  flex-shrink:0;
  width:22px;height:22px;border-radius:50%;
  background:rgba(251,213,88,.15);
  padding:4px;color:var(--gold);
}

/* ─── FINAL CTA ────────────────────────────────────────────── */
.final-cta{
  padding:100px 0;text-align:center;
  background:var(--paper-2);
}
.final-cta h2{
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(36px,5vw,64px);font-weight:600;
  line-height:1.05;letter-spacing:-.02em;
  max-width:600px;margin:0 auto 16px;
  opacity:0;transform:translateY(20px);
}
.final-cta p{
  font-size:16px;color:var(--ink-soft);max-width:420px;
  margin:0 auto 36px;line-height:1.6;
  opacity:0;
}
.final-cta-actions{
  display:flex;flex-wrap:wrap;gap:14px;justify-content:center;
  opacity:0;
}
.btn-cta-dark{
  display:inline-flex;align-items:center;gap:9px;
  background:var(--teal);color:#fff;
  font-size:15px;font-weight:600;
  padding:16px 28px;border-radius:999px;
  transition:background .2s,transform .2s;
}
.btn-cta-dark:hover{background:var(--teal-2);transform:translateY(-2px)}
.btn-cta-gold{
  display:inline-flex;align-items:center;gap:9px;
  background:var(--gold);color:var(--teal);
  font-size:15px;font-weight:700;
  padding:14px 26px;border-radius:999px;
  transition:background .2s,transform .2s;
}
.btn-cta-gold:hover{background:#fff;transform:translateY(-2px)}

/* ─── FOOTER ───────────────────────────────────────────────── */
.footer{background:var(--teal);padding:56px 0 0}
.footer-inner{
  display:flex;align-items:flex-start;justify-content:space-between;
  gap:48px;flex-wrap:wrap;padding-bottom:48px;
  border-bottom:1px solid rgba(246,242,234,.1);
}
.footer-brand img{height:40px;margin-bottom:14px;opacity:.9}
.footer-brand p{font-size:13px;color:rgba(246,242,234,.55);max-width:260px;line-height:1.6}
.footer-col h4{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);margin-bottom:16px}
.footer-col ul{list-style:none;display:flex;flex-direction:column;gap:10px}
.footer-col ul a{font-size:14px;color:rgba(246,242,234,.72);transition:color .18s}
.footer-col ul a:hover{color:#fff}
.footer-wa{display:inline-flex;align-items:center;gap:9px;background:var(--gold);color:var(--teal);font-size:14px;font-weight:700;padding:13px 22px;border-radius:999px;transition:.2s}
.footer-wa:hover{background:#fff}
.footer-copy{padding:20px 0;font-size:12px;color:rgba(246,242,234,.35);text-align:center}

/* ─── RESPONSIVE ───────────────────────────────────────────── */
@media(max-width:900px){
  .process-grid{grid-template-columns:1fr}
  .confidential-card{grid-template-columns:1fr;padding:48px 40px;gap:40px}
}
@media(max-width:680px){
  .wrap,.nav{padding-left:18px;padding-right:18px}
  .nav-links{display:none}
  .burger{display:flex}
  .mobile-menu{display:flex}
  .hero-content{padding-bottom:60px;padding-left:18px;padding-right:18px}
  .process{padding:72px 0}
  .process-head-right{max-width:none}
  .confidential-card{padding:36px 24px}
  .final-cta{padding:72px 0}
  .footer-inner{flex-direction:column;gap:32px}
}
</style>
